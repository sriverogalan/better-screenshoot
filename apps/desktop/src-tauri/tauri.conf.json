{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Better Screenshoot",
  "version": "0.5.0",
  "identifier": "com.betterscreenshoot.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Better Screenshoot",
        "width": 960,
        "height": 640,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "maximizable": true,
        "center": true,
        "backgroundColor": "#1E1E20"
      },
      {
        "label": "overlay",
        "title": "Capture",
        "url": "/overlay",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "fullscreen": false
      },
      {
        "label": "editor",
        "title": "Editor",
        "url": "/editor",
        "width": 900,
        "height": 700,
        "visible": false,
        "decorations": false,
        "center": true,
        "resizable": true,
        "preventOverflow": true,
        "backgroundColor": "#1E1E20"
      },
      {
        "label": "menubar",
        "url": "/menubar",
        "width": 300,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$PICTURE/**",
          "$HOME/**",
          "$CACHE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "shortDescription": "Screenshots with a built-in editor",
    "longDescription": "Better Screenshoot captures screen, window, or region, edits with annotations, and saves to history.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "autostart": null,
    "deep-link": {
      "desktop": {
        "schemes": [
          "betterscreenshoot"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFMjhCRjY5ODdFNUY5Q0QKUldUTitlV0hhYjhvamxaTUlrU01VNmdYQVZDek5iSlM2QTJmaFVYL3g5bURkNHQ5bVlrcmoydTcK",
      "endpoints": [
        "https://github.com/sriverogalan/better-screenshoot/releases/latest/download/latest.json"
      ]
    }
  }
}
