{
  "name": "better-screenshoot-raycast",
  "title": "Better Screenshoot",
  "description": "Trigger Better Screenshoot captures from Raycast",
  "icon": "extension-icon.png",
  "author": "better-screenshoot",
  "license": "MIT",
  "commands": [
    {
      "name": "capture-area",
      "title": "Capture Area",
      "description": "Select a region to capture",
      "mode": "no-view"
    },
    {
      "name": "capture-screen",
      "title": "Capture Screen",
      "description": "Capture the full screen",
      "mode": "no-view"
    },
    {
      "name": "capture-window",
      "title": "Capture Window",
      "description": "Capture a specific window",
      "mode": "no-view"
    },
    {
      "name": "open-history",
      "title": "Open History",
      "description": "Open capture history",
      "mode": "no-view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "test": "tsc --noEmit"
  }
}
