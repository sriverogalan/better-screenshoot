{
  "name": "better-screenshoot",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @better-screenshoot/desktop tauri dev",
    "build": "pnpm --filter @better-screenshoot/desktop tauri build",
    "build:mac": "pnpm --filter @better-screenshoot/desktop tauri build -- --bundles dmg",
    "release:mac": "bash scripts/release-mac.sh",
    "sync-version": "node scripts/sync-version.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --filter '!@better-screenshoot/cli' test",
    "typecheck": "pnpm -r typecheck",
    "raycast:dev": "bash scripts/raycast-dev.sh"
  },
  "devDependencies": {
    "typescript": "~5.6.2"
  },
  "packageManager": "pnpm@9.15.0"
}
